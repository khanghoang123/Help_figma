architecture-beta
    group frontend(cloud)[Frontend]
    group backend(cloud)[Backend]
    group data(cloud)[Data Plane]
    group ml(cloud)[ML Plane]

    service web(server)[Nextjs Web] in frontend
    service api(server)[FastAPI API] in backend
    service cache(database)[Redis Cache] in backend

    service db(database)[Postgres SQLite] in data
    service crawler(server)[Crawler Worker] in data
    service sources(internet)[News Sources]

    service labeling(server)[Labeling Worker] in ml
    service inference(server)[Inference Service] in ml

    sources:B --> T:crawler
    crawler:R --> L:db
    api:B --> T:db
    api:R --> L:cache
    web:B --> T:api
    api:R --> L:inference
    labeling:R --> L:db
    inference:R --> L:db

classDiagram
  class Source {
    +int id
    +string source_id
    +string name
    +string domain
    +list rss_urls
    +bool enabled
    +bool robots_ok
  }

  class Article {
    +int id
    +string url
    +string url_hash
    +string title
    +string category
    +datetime published_at
    +string language
    +string status
  }

  class Summary {
    +int id
    +string summary_text
    +string model_name
    +string prompt_version
    +bool is_published
  }

  class Label {
    +int id
    +string source
    +string summary_text
    +string prompt_version
    +string quality
    +bool qc_passed
  }

  class CrawlRun {
    +int id
    +datetime started_at
    +datetime ended_at
    +int n_new
    +int n_skipped
    +int n_errors
    +string status
  }

  class DatasetVersion {
    +int id
    +string name
    +list train_ids
    +list val_ids
    +list test_ids
  }

  class ModelRun {
    +int id
    +string model_name
    +string version
    +dict params
    +dict metrics
    +string artifact_path
  }

  Source "1" --> "many" Article
  Source "1" --> "many" CrawlRun
  Article "1" --> "many" Summary
  Article "1" --> "many" Label
  ModelRun "*" --> "0..1" DatasetVersion

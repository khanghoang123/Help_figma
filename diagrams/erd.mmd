  SOURCE {
    int id PK
    string source_id
    string name
    string domain
    list rss_urls
    bool enabled
  }
  ARTICLE {
    int id PK
    int source_fk FK
    string url
    string url_hash
    string title
    string category
    datetime published_at
    string status
  }
  SUMMARY {
    int id PK
    int article_fk FK
    string model_name
    string prompt_version
    bool is_published
  }
  LABEL {
    int id PK
    int article_fk FK
    string source
    string quality
    bool qc_passed
  }
  CRAWL_RUN {
    int id PK
    int source_fk FK
    datetime started_at
    datetime ended_at
    int n_new
    int n_skipped
    int n_errors
    string status
  }
  DATASET_VERSION {
    int id PK
    string name
    list train_ids
    list val_ids
    list test_ids
  }
  MODEL_RUN {
    int id PK
    string model_name
    string version
    string artifact_path
    int dataset_version_fk FK
  }

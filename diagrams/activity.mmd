flowchart TD
  Start([Start])
  LoadConfig[Load sources.yaml]
  Discover[Discover RSS items]
  Seen{Seen URL?}
  Robots{Robots allow?}
  Fetch[Fetch HTML]
  Extract[Extract text]
  ExtractOk{Extract ok?}
  Dedupe{Near-duplicate?}
  Persist[Persist article]
  Enqueue[Enqueue for inference]
  Skip[Skip item]
  End([End])

  Start --> LoadConfig --> Discover --> Seen
  Seen -- yes --> Skip --> End
  Seen -- no --> Robots
  Robots -- no --> Skip --> End
  Robots -- yes --> Fetch --> Extract --> ExtractOk
  ExtractOk -- no --> Skip --> End
  ExtractOk -- yes --> Dedupe
  Dedupe -- yes --> Skip --> End
  Dedupe -- no --> Persist --> Enqueue --> End
